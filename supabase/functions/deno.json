{
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true,
    "experimentalDecorators": false
  },
  "imports": {
    "supabase": "https://esm.sh/@supabase/supabase-js@2",
    "openai": "npm:openai@^4"
  },
  "tasks": {
